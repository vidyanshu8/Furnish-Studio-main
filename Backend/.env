# MongoDB Connection String
# Local MongoDB
MONGODB_URI=mongodb://localhost:27017/decoview

# MongoDB Atlas (Cloud)
# MONGODB_URI=mongodb+srv://<USERNAME>:<PASSWORD>@<CLUSTER>.mongodb.net/

# JWT Secret Key
JWT_SECRET=<YOUR_JWT_SECRET>

# OpenAI API Key
OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>

# Server Port
PORT=5000
